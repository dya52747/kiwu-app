<title>KiWu-App neu</title>
<meta name="theme-color" content="#8B4A6B">
<link rel="manifest" href="manifest.webmanifest">
<style>
:root{--rose:#8B4A6B;--rose2:#D4A8C0;--rosebg:#FDF0F5;--green:#66BB6A;--text:#2D1B0E;--soft:#9A7D7D;--bg:#FDF8F4;--orange:#E65100;--stim:#C62828;--blue:#1F5FA6;--card:#fffdfb;--line:rgba(45,27,14,.14);--shadow:0 18px 45px rgba(80,50,40,.08)}
*{box-sizing:border-box}body{margin:0;background:var(--bg);color:var(--text);font-family:Georgia,serif}button,input,select,textarea{font:inherit}#app{max-width:1120px;margin:0 auto;padding:14px}.hero{background:linear-gradient(135deg,#8B4A6B,#C4797A,#E8A87C);color:white;border-radius:26px;padding:24px;box-shadow:var(--shadow)}.hero.stim{background:linear-gradient(135deg,#B71C1C,#E53935,#EF6C00)}h1{margin:0;font-size:clamp(30px,7vw,52px);line-height:1}.chips{display:flex;flex-wrap:wrap;gap:8px;margin-top:14px}.chip{background:rgba(255,255,255,.22);border-radius:999px;padding:8px 11px;font-weight:700}.nav{display:grid;grid-template-columns:repeat(5,1fr);gap:8px;margin:12px 0}.nav button{border:0;border-radius:15px;background:white;padding:11px 6px;font-weight:700}.nav .active{background:var(--rosebg);color:var(--rose);box-shadow:inset 0 -3px 0 var(--rose)}.stimtab{color:#B71C1C!important;background:#ffebee!important}.card{background:var(--card);border-radius:24px;padding:18px;margin:14px 0;box-shadow:var(--shadow);border:1px solid rgba(255,255,255,.8)}.grid{display:grid;grid-template-columns:repeat(2,1fr);gap:14px}.tiles{display:grid;grid-template-columns:repeat(4,1fr);gap:10px}.tile{background:rgba(255,255,255,.25);border-radius:17px;padding:14px}.tile b{display:block;font-size:24px}.phase{border-left:8px solid var(--rose)}.p0{background:#FFF5F5;border-color:#D32F2F}.p1{background:#F0F7FF;border-color:#1976D2}.p2{background:#F0FFF1;border-color:#2E7D32}.p3{background:#FAF0FF;border-color:#8E24AA}.warn{background:#ffebee}.ok{background:#f1fff4}.btn{border:0;background:var(--rose);color:white;border-radius:14px;padding:11px 13px;font-weight:700}.btn2{background:#f3e4eb;color:var(--rose)}.danger{background:var(--stim)}.row{display:flex;gap:8px;flex-wrap:wrap}.form{display:grid;grid-template-columns:repeat(2,1fr);gap:10px}.inp,select,textarea{width:100%;border:1px solid var(--line);border-radius:14px;padding:11px;background:white}textarea{min-height:90px}.cal{display:grid;grid-template-columns:repeat(7,1fr);gap:6px}.day{min-height:74px;border:1px solid var(--line);background:white;border-radius:14px;padding:7px;text-align:left}.today{outline:3px solid var(--rose)}.bg0{background:#FFCDD2}.bg1{background:#BBDEFB}.bg2{background:#C8E6C9}.bg3{background:#E1BEE7}.small{font-size:11px;color:var(--soft)}.opts{display:grid;grid-template-columns:repeat(3,1fr);gap:8px}.opt{border:1px solid var(--line);background:white;border-radius:16px;padding:11px;text-align:center}.sel,.done{outline:3px solid var(--rose);background:var(--rosebg)}.log{display:grid;gap:8px}.item{background:white;border:1px solid var(--line);border-radius:15px;padding:11px}.bars{display:grid;grid-template-columns:repeat(7,1fr);gap:6px;align-items:end;height:110px}.wb{display:flex;flex-direction:column;align-items:center;justify-content:end;font-size:11px}.wb div{width:22px;background:var(--rose2);border-radius:8px 8px 0 0;min-height:4px}.wb.today div{background:var(--rose)}.footer{text-align:center;color:var(--soft);font-size:13px;margin:20px}.hidden{display:none}@media(max-width:800px){#app{padding:10px}.nav{grid-template-columns:repeat(5,auto);overflow:auto}.grid,.tiles,.form,.opts{grid-template-columns:1fr}.day{min-height:56px;font-size:12px}}
</style>
</head>
<body><div id="app"></div>
<script>
const K={cd1:"kiwu_cd1",sc:"kiwu_sc",sl:"kiwu_sl",ov:"kiwu_ov",ll:"kiwu_ll",cy:"kiwu_cy",stim:"kiwu_stim",bd:"kiwu_bd",ls:"kiwu_ls"};
const PH=[["🔴","Menstruation","#D32F2F","Regeneration, Wärme, Eisen"],["🔵","Aufbauphase","#1976D2","Energie steigt, Protein und Aufbau"],["🟢","Eisprung","#2E7D32","Frisch, bunt, intuitiv"],["🟣","Lutealphase","#8E24AA","Stabilisieren, Schlaf, Blutzucker"]];
const SPORTS=[["joggen","🏃","Joggen","Cardio"],["walking","🚶","Nord. Walking","Cardio"],["spazieren","🌿","Spazieren","Cardio"],["bodypump","🏋️","BodyPump","Les Mills"],["bodybalance","☯️","BodyBalance","Les Mills"],["bodycombat","🥊","BodyCombat","Les Mills"],["core","🔥","Core","Les Mills"],["yoga","🧘","Mady Yoga","Yoga"],["pilates","🤸","Pilates","Yoga"],["dehnen","🌀","Dehnen","Yoga"],["tone","🏋️","Tone/Core","Kraft"],["kraft","💪","Kraft","Kraft"]];
const SF=[["paranuss","🥜 2 Paranüsse","Selen","Max. 2",0],["hanf","🌱 Hanfsamen 10g","Vollprotein","",0],["sonnenbl","🌻 Sonnenblumenkerne 8g","Vitamin E","",0],["blaubeeren","🫐 Blaubeeren 80g","Antioxidantien","",0],["lein","🌾 Leinsamenschrot 8g","Omega-3","",0],["kurkuma","🟡 Kurkuma + Pfeffer","Entzündung","mit Pfeffer",0],["rotebeete","🔴 Rote Beete 75g","Durchblutung","",0],["edamame","🫛 Edamame 60g","Folsäure","",0],["maca","🟤 Maca 4g","Hormonbalance","Mo & Do",1]];
const FOOD=[
{t:"Menstruation",n:["🩸 Eisen","💊 Magnesium","🐟 Omega-3","🌿 Folsäure"],f:["Rote Beete","Blattspinat","Beluga-Linsen","Kiwi","warme Suppen"],a:["Koffein mit Essen","sehr kalte Mahlzeiten"],tip:"Rote Beete + Spinat täglich."},
{t:"Aufbauphase",n:["🥚 Protein","🌿 Folsäure","🥑 gesunde Fette"],f:["Skyr","Linsen","Tofu","mediterrane Bowl","Beeren"],a:["zu wenig Protein"],tip:"Protein auf 3–4 Mahlzeiten verteilen."},
{t:"Eisprung",n:["🟢 Antioxidantien","💧 Flüssigkeit","🥑 Omega-3"],f:["Beeren","Avocado","grünes Gemüse","Edamame"],a:["zu viel Druck"],tip:"Bunt, frisch, mediterran."},
{t:"Lutealphase",n:["🌾 Ballaststoffe","💊 Magnesium","🥚 Protein"],f:["Haferflocken","Kichererbsen","Süßkartoffel","Nüsse","warme Gerichte"],a:["zu wenig essen","zu intensiv trainieren"],tip:"Protein + Ballaststoffe pro Mahlzeit."}
];
let S={tab:"heute",cd1:null,cal:null,bd:{},sc:{},sfDate:null,sl:{},stype:null,sdur:30,sint:"mittel",sdate:null,snote:"",ov:{},ll:14,stim:{active:false,startDate:null,etDate:null,afterTransfer:false},ePhase:null,cycles:[],last:null};
const d=()=>new Date(), key=x=>{let z=new Date(x.getTime()-x.getTimezoneOffset()*60000);return z.toISOString().slice(0,10)}, pd=k=>new Date(k+"T00:00:00"), add=(x,n)=>{let z=new Date(x);z.setDate(z.getDate()+n);return z}, dif=(a,b)=>Math.round((new Date(b.getFullYear(),b.getMonth(),b.getDate())-new Date(a.getFullYear(),a.getMonth(),a.getDate()))/86400000);
async function get(k){return localStorage.getItem(k)} async function set(k,v){localStorage.setItem(k,v);localStorage.setItem(K.ls,new Date().toISOString());S.last=new Date().toISOString()}
function cd(x=d()){return S.cd1?dif(pd(S.cd1),x)+1:null} function pidx(n){return n<=5?0:n<=13?1:n<=16?2:3}
function latestOv(){let a=Object.keys(S.ov).filter(k=>S.ov[k]).sort();return a.at(-1)||null}
function dpo(x=d()){let o=latestOv();return o?dif(pd(o),x):null}
function smartPhase(x=d()){let c=cd(x)||1,o=latestOv();if(!o){if(c>16)return {...PH[1],idx:1,wait:1};return {...PH[pidx(c)],idx:pidx(c)}}let n=dif(pd(o),x);return n<0?{...PH[1],idx:1}:n===0?{...PH[2],idx:2}:{...PH[3],idx:3}}
function sportByCd(n){let i=pidx(n);return i===0?{note:"Regeneration",y:"✅",nw:"✅",pi:"💛",bb:"✅",jog:"0",ba:"0",core:"0",kraft:"0"}:i===1?{note:"Aufbau",y:"✅",nw:"✅",pi:"✅",bb:"✅",jog:"✅",ba:"💛",core:"✅",kraft:"✅"}:i===2?{note:"Biologisches Hoch",y:"✅",nw:"✅",pi:"✅",bb:"✅",jog:"✅",ba:"✅",core:"✅",kraft:"✅"}:{note:"Sanfter stabilisieren",y:"✅",nw:"✅",pi:"✅",bb:"✅",jog:"💛",ba:"0",core:"💛",kraft:"💛"}}
function smartSport(){let n=dpo();if(n===null||n<0)return null;if(n<=2)return{note:"DPO 0–2: alles nach Gefühl",y:"✅",nw:"✅",pi:"✅",bb:"✅",jog:"✅",ba:"✅",core:"✅",kraft:"✅"};if(n<=5)return{note:"DPO 3–5: moderat",y:"✅",nw:"✅",pi:"✅",bb:"✅",jog:"💛",ba:"0",core:"✅",kraft:"💛"};if(n<=9)return{note:"Einnistungsfenster: sanft, kein Joggen",y:"✅",nw:"✅",pi:"✅",bb:"✅",jog:"0",ba:"0",core:"💛",kraft:"0"};return{note:"DPO 10+: sehr sanft",y:"✅",nw:"✅",pi:"0",bb:"✅",jog:"0",ba:"0",core:"0",kraft:"0"}}
function predPeriod(){let o=latestOv();return o?key(add(pd(o),S.ll)):null}
function predOv(){return S.cd1?key(add(d(),14-(cd()||1))):null}
function sfKey(){return S.sfDate||key(d())} function selKey(){return S.sdate||key(d())}
function sfCount(k=sfKey()){let o=S.sc[k]||{};return SF.filter(x=>o[x[0]]).length}
function sportToday(k=key(d())){let a=S.sl[k]||[];return{min:a.reduce((s,x)=>s+Number(x.duration||0),0),icons:a.map(x=>x.icon).join(" ")}}
function bg(x){let c=cd(x);if(!c)return"";if(c<=5)return"bg0";let cell=key(x), ov=Object.keys(S.ov).filter(k=>S.ov[k]).sort().find(k=>pd(k)<=x);if(ov){return dif(pd(ov),x)===0?"bg2":"bg3"}return c>=14&&c<=16?"bg2":"bg1"}
async function load(){S.cd1=await get(K.cd1);for(let [a,b] of [["sc","sc"],["sl","sl"],["ov","ov"],["cycles","cy"],["stim","stim"],["bd","bd"]]){let v=await get(K[b]);if(v)try{S[a]=JSON.parse(v)}catch(e){}}let l=await get(K.ll);if(l)S.ll=+l;S.last=await get(K.ls);if(!S.cd1){S.cd1=key(add(d(),-5));S.cycles=[{id:"cycle_1",startDate:S.cd1,endDate:null,ovulationDate:null,ovulationDay:null,length:null,lutealLength:S.ll}]}if(!S.cal)S.cal={y:d().getFullYear(),m:d().getMonth()};render()}
async function save(){await set(K.cd1,S.cd1);await set(K.sc,JSON.stringify(S.sc));await set(K.sl,JSON.stringify(S.sl));await set(K.ov,JSON.stringify(S.ov));await set(K.ll,String(S.ll));await set(K.cy,JSON.stringify(S.cycles));await set(K.stim,JSON.stringify(S.stim));await set(K.bd,JSON.stringify(S.bd))}
function tab(t){S.tab=t;render()}
function header(){let c=cd()||1,ph=smartPhase(),sp=sportToday();return `<div class="hero ${S.stim.active?'stim':''}"><h1>🌸 KiWu-App</h1><div class="chips"><span class="chip">ZT ${c}</span><span class="chip">${ph[0]} ${ph[1]}</span><span class="chip">🏃 ${sp.min} Min ${sp.icons}</span><span class="chip">Superfoods ${sfCount()}/9</span></div></div><div class="nav">${[["heute","🏠 Heute"],["zyklus","📅 Zyklus"],["ernaehrung","🥗 Ernährung"],["ivf","💉 IVF"],["kiwu","⭐ KiWu"]].map(x=>`<button class="${S.tab===x[0]?'active':''} ${x[0]=='ivf'&&S.stim.active?'stimtab':''}" onclick="tab('${x[0]}')">${x[1]}</button>`).join("")}</div>`}
function render(){let b=S.tab=="heute"?heute():S.tab=="zyklus"?zyklus():S.tab=="ernaehrung"?ernaehrung():S.tab=="ivf"?ivf():kiwu();app.innerHTML=header()+b+`<div class="footer">Gespeichert: ${S.last?new Date(S.last).toLocaleString("de-DE"):"noch nicht"}</div>`}
function heute(){let c=cd()||1,ph=smartPhase(),sp=smartSport()||sportByCd(Math.min(c,30)),dp=dpo(),st=sportToday();let dpot=dp===null?"Eisprung nicht bestätigt":dp===0?"🟢 Heute!":dp>0?"DPO "+dp:"in "+Math.abs(dp)+" T.";return `<div class="card phase p${ph.idx}"><h2>${ph[0]} ${ph[1]}</h2><p>${ph[3]} ${ph.wait?'⌛ Warte auf Eisprung-Bestätigung':''}</p><button class="btn btn2" onclick="newCycle()">Neuen Zyklus starten</button></div>${S.stim.active?`<div class="card warn"><h2>💉 Stimulation aktiv</h2><p>Start: ${S.stim.startDate||"—"} · ET: ${S.stim.etDate||"—"}</p><p>Yoga ✅ · Nordic Walking 💛 · Rest ❌</p></div>`:""}<div class="hero"><div class="tiles"><div class="tile">Zyklustag<b>${c}</b></div><div class="tile">Sport<b>${st.min} Min</b></div><div class="tile">Superfoods<b>${sfCount()}/9</b></div><div class="tile">Eisprung/DPO<b>${dpot}</b></div></div></div><div class="grid"><div class="card"><h2>🏃 Empfehlung</h2>${sportMatrix(sp)}</div><div class="card"><h2>🏃 Tracker</h2>${sportTracker()}</div></div><div class="card"><h2>🥜 Superfoods</h2>${superfoods()}</div><div class="card ok"><h2>🥗 Ernährung</h2><button class="btn" onclick="tab('ernaehrung')">Zum Ernährungs-Tab</button></div>`}
function sportMatrix(sp){let l={y:"Yoga",nw:"Walking",pi:"Pilates",bb:"Balance",jog:"Joggen",ba:"Attack/Combat",core:"Core",kraft:"Kraft"};return `<p><b>${sp.note}</b></p><div class="opts">${Object.keys(l).map(k=>`<div class="opt"><b>${l[k]}</b><br><span style="font-size:28px">${sp[k]||"0"}</span></div>`).join("")}</div>`}
function sportTracker(){let cats=[...new Set(SPORTS.map(x=>x[3]))];let h=`<div class="form"><input class="inp" type="date" value="${selKey()}" max="${key(d())}" onchange="S.sdate=this.value"><input class="inp" placeholder="Notiz" value="${S.snote||""}" oninput="S.snote=this.value"></div>`;for(let cat of cats){h+=`<h3>${cat}</h3><div class="opts">${SPORTS.filter(x=>x[3]==cat).map(x=>`<button class="opt ${S.stype===x[0]?'sel':''}" onclick="S.stype='${x[0]}';render()">${x[1]}<br>${x[2]}</button>`).join("")}</div>`}h+=`<div class="row" style="margin-top:10px">${[15,20,30,45,60,75,90].map(m=>`<button class="btn btn2" onclick="S.sdur=${m};render()">${m}</button>`).join("")}${["leicht","mittel","intensiv"].map(i=>`<button class="btn btn2" onclick="S.sint='${i}';render()">${i}</button>`).join("")}<button class="btn" onclick="addSport()">✅ Eintragen</button></div>${weekBars()}`;return h}
async function addSport(){if(!S.stype)return alert("Sportart wählen");let t=SPORTS.find(x=>x[0]==S.stype),k=selKey();S.sl[k]??=[];S.sl[k].push({id:t[0],icon:t[1],label:t[2],duration:S.sdur,intensity:S.sint,note:S.snote,time:new Date().toTimeString().slice(0,5),cycleDay:cd(pd(k))});S.snote="";await save();render()}
function weekBars(){let h='<div class="bars">';for(let i=6;i>=0;i--){let x=add(d(),-i),k=key(x),m=sportToday(k).min;h+=`<div class="wb ${i==0?'today':''}"><span>${m}</span><div style="height:${Math.max(4,m/90*95)}px"></div><span>${x.toLocaleDateString('de-DE',{weekday:'short'}).slice(0,2)}</span></div>`}return h+"</div>"}
function superfoods(){let k=sfKey(),o=S.sc[k]||{};return `<input class="inp" type="date" value="${k}" max="${key(d())}" onchange="S.sfDate=this.value;render()"><div class="opts" style="margin-top:10px">${SF.map(s=>{let forbid=S.stim.active&&s[4];return `<button class="opt ${o[s[0]]?'done':''}" ${forbid?'disabled':''} onclick="togSF('${s[0]}')"><b>${s[1]}</b><br><small>${s[2]}</small><br><small>${forbid?'🚫 Stimulation':s[3]}</small></button>`}).join("")}</div><p>${sfCount(k)}/9 Superfoods</p>`}
async function togSF(id){let k=sfKey();S.sc[k]??={};S.sc[k][id]=!S.sc[k][id];await save();render()}
function zyklus(){let m=S.cal, first=new Date(m.y,m.m,1), last=new Date(m.y,m.m+1,0), off=(first.getDay()+6)%7, pp=predPeriod(), po=predOv();let h=`<div class="card"><div class="row" style="justify-content:space-between"><button class="btn btn2" onclick="moveM(-1)">‹</button><h2>${first.toLocaleDateString('de-DE',{month:'long',year:'numeric'})}</h2><button class="btn btn2" onclick="moveM(1)">›</button></div><div class="cal">${["Mo","Di","Mi","Do","Fr","Sa","So"].map(w=>`<b>${w}</b>`).join("")}`;for(let i=0;i<off;i++)h+='<div></div>';for(let j=1;j<=last.getDate();j++){let x=new Date(m.y,m.m,j),k=key(x),c=cd(x);let mark=(S.ov[k]?"🟢":"")+(k==pp?"🔴":"")+(k==po?"🔵":"")+((S.sl[k]||[]).length?"🏃":"")+(S.bd[k]?"🩸":"");h+=`<button class="day ${bg(x)} ${k==key(d())?'today':''}" onclick="bleed('${k}')"><b>${j}</b><span class="small">ZT ${c||'—'}</span><span>${mark}</span></button>`}h+='</div></div>';h+=`<div class="grid"><div class="card"><h2>🥚 Ovulation</h2><input class="inp" type="date" id="ovIn" value="${key(d())}" max="${key(d())}"><button class="btn" onclick="addOv()">Positiven Test speichern</button><p>DPO: ${dpo()??'—'} · Periode erwartet: ${pp||'—'}</p><div class="row">${[12,13,14,15,16].map(x=>`<button class="btn btn2" onclick="setLL(${x})">${x} Tage</button>`).join("")}</div></div><div class="card"><h2>📈 Verlauf</h2>${hist()}</div></div>`;return h}
function moveM(n){S.cal.m+=n;if(S.cal.m<0){S.cal.m=11;S.cal.y--}if(S.cal.m>11){S.cal.m=0;S.cal.y++}render()}
async function bleed(k){S.bd[k]=!S.bd[k];await save();render()} async function addOv(){let v=ovIn.value||key(d());S.ov[v]=true;let c=S.cycles.find(x=>!x.endDate);if(c){c.ovulationDate=v;c.ovulationDay=cd(pd(v))}await save();render()} async function setLL(x){S.ll=x;let c=S.cycles.find(x=>!x.endDate);if(c)c.lutealLength=x;await save();render()}
function hist(){let closed=S.cycles.filter(c=>c.endDate);let al=closed.length?Math.round(closed.reduce((s,c)=>s+(c.length||0),0)/closed.length):"—";let ovs=closed.filter(c=>c.ovulationDay),ao=ovs.length?Math.round(ovs.reduce((s,c)=>s+c.ovulationDay,0)/ovs.length):"—";return `<p>Ø Zyklus: ${al} · Ø Eisprung: ZT ${ao}</p><div class="log">${S.cycles.map(c=>`<div class="item"><b>${c.startDate}</b> → ${c.endDate||'aktuell'}<br>Länge: ${c.length||'—'} · Eisprung: ${c.ovulationDay||'—'} · Luteal: ${c.lutealLength||14}</div>`).join("")}</div>`}
async function newCycle(){if(!confirm("Neuen Zyklus heute starten?"))return;let y=key(add(d(),-1)),c=S.cycles.find(x=>!x.endDate);if(c){c.endDate=y;c.length=dif(pd(c.startDate),pd(y))+1}S.cd1=key(d());S.cycles.push({id:"cycle_"+Date.now(),startDate:S.cd1,endDate:null,ovulationDate:null,ovulationDay:null,length:null,lutealLength:S.ll});await save();render()}
