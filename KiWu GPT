<svg xmlns="http://www.w3.org/2000/svg" width="512" height="512"><rect width="512" height="512" rx="110" fill="#FDF0F5"/><text x="256" y="310" text-anchor="middle" font-size="190">🌸</text></svg>
<!doctype html>
<html lang="de">
<head>
<meta charset="utf-8">
